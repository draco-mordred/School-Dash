{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/dist/src/server.js",
      "use": "@vercel/node"
    }
  ],
    "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/dist/src/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/((?!assets/).*)",
      "dest": "frontend/index.html"
    }
  ]
}