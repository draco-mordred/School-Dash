{
  "version": 2,
  
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  
  "env": {
    "NODE_ENV": "production",
    "VITE_API_BASE_URL": "/api"
  },
  
"rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}